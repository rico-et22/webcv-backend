/* =========================================================
   webCV — Generated Portfolio Stylesheet
   Vanilla CSS, no external dependencies
   ========================================================= */

/* --- Inter variable font (self-hosted) --- */
@font-face {
  font-family: 'Inter';
  font-style: normal;
  font-weight: 100 900;
  font-display: swap;
  src: url('{{{fontSrc}}}') format('woff2');
  unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA,
    U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193,
    U+2212, U+2215, U+FEFF, U+FFFD;
}

/* --- Color tokens --- */
:root {
  --color-bg: #ffffff;
  --color-bg-secondary: #f8fafc;
  --color-bg-card: #ffffff;
  --color-border: #e2e8f0;
  --color-text: #0f172a;
  --color-text-muted: #64748b;
  --color-text-subtle: #94a3b8;
  --color-primary: #0284c7;
  --color-primary-hover: #0369a1;
  --color-badge-bg: #f1f5f9;
  --color-badge-text: #334155;
  --color-badge-border: #e2e8f0;
  --color-hero-from: #06b6d4;
  --color-hero-to: #0284c7;
  --color-hero-text: #ffffff;
  --color-shadow: rgba(0, 0, 0, 0.06);
  --color-shadow-md: rgba(0, 0, 0, 0.10);
  --color-focus: #0284c7;
}

@media (prefers-color-scheme: dark) {
  :root {
    --color-bg: #09090b;
    --color-bg-secondary: #111113;
    --color-bg-card: #18181b;
    --color-border: #27272a;
    --color-text: #fafafa;
    --color-text-muted: #a1a1aa;
    --color-text-subtle: #71717a;
    --color-primary: #38bdf8;
    --color-primary-hover: #7dd3fc;
    --color-badge-bg: #27272a;
    --color-badge-text: #d4d4d8;
    --color-badge-border: #3f3f46;
    --color-hero-from: #0e7490;
    --color-hero-to: #075985;
    --color-hero-text: #f0f9ff;
    --color-shadow: rgba(0, 0, 0, 0.3);
    --color-shadow-md: rgba(0, 0, 0, 0.45);
    --color-focus: #38bdf8;
  }
}

/* --- Reset & base --- */
*, *::before, *::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

html {
  scroll-behavior: smooth;
  font-size: 16px;
}

body {
  font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto,
    'Helvetica Neue', Arial, sans-serif;
  background-color: var(--color-bg);
  color: var(--color-text);
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

img {
  max-width: 100%;
  height: auto;
  display: block;
}

a {
  color: var(--color-primary);
  text-decoration: none;
}

a:hover {
  color: var(--color-primary-hover);
  text-decoration: underline;
}

a:focus-visible {
  outline: 2px solid var(--color-focus);
  outline-offset: 3px;
  border-radius: 2px;
}

ul {
  list-style: none;
}

/* --- Skip link (a11y) --- */
.skip-link {
  position: absolute;
  left: -9999px;
  top: auto;
  width: 1px;
  height: 1px;
  overflow: hidden;
  z-index: 9999;
  background: var(--color-bg);
  color: var(--color-text);
  padding: 0.5rem 1rem;
  border: 2px solid var(--color-focus);
  border-radius: 4px;
  font-weight: 600;
}

.skip-link:focus {
  position: fixed;
  top: 1rem;
  left: 1rem;
  width: auto;
  height: auto;
  overflow: visible;
}

/* --- Layout container --- */
.container {
  width: 100%;
  max-width: 48rem;
  margin-left: auto;
  margin-right: auto;
  padding-left: 1.25rem;
  padding-right: 1.25rem;
}

/* --- Hero section --- */
.hero {
  background: linear-gradient(135deg, var(--color-hero-from), var(--color-hero-to));
  color: var(--color-hero-text);
  padding: 3rem 0 3.5rem;
}

.hero .container {
  display: flex;
  flex-direction: column;
  gap: 2rem;
  align-items: center;
  text-align: center;
}

.hero-body {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
  flex: 1;
}

.hero-greeting {
  font-size: 1rem;
  font-weight: 500;
  opacity: 0.9;
  letter-spacing: 0.025em;
}

.hero-name {
  font-size: 2.25rem;
  font-weight: 800;
  line-height: 1.15;
  letter-spacing: -0.025em;
}

.hero-name strong {
  display: inline;
}

.hero-jobtitle {
  font-size: 1.125rem;
  font-weight: 500;
  opacity: 0.85;
}

.hero-bio {
  font-size: 0.9375rem;
  opacity: 0.8;
  max-width: 36rem;
  margin: 0 auto;
  line-height: 1.65;
}

.hero-location {
  display: inline-flex;
  align-items: center;
  gap: 0.375rem;
  font-size: 0.875rem;
  opacity: 0.75;
  margin-top: 0.25rem;
}

.hero-avatar {
  flex-shrink: 0;
}

.avatar {
  width: 6rem;
  height: 6rem;
  border-radius: 9999px;
  object-fit: cover;
  border: 3px solid rgba(255, 255, 255, 0.4);
  box-shadow: 0 4px 16px var(--color-shadow-md);
}

/* --- Main content area --- */
main {
  padding: 2.5rem 0 4rem;
}

main .container {
  display: flex;
  flex-direction: column;
  gap: 3rem;
}

/* --- Section --- */
section {
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
}

.section-header {
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
}

.section-label {
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--color-primary);
}

.section-title {
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--color-text);
  line-height: 1.25;
}

/* --- About section --- */
.about-text {
  font-size: 0.9375rem;
  color: var(--color-text-muted);
  line-height: 1.75;
  max-width: 40rem;
}

/* --- Experience & Education --- */
.timeline {
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
}

.timeline-item {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  padding: 1.25rem;
  background: var(--color-bg-card);
  border: 1px solid var(--color-border);
  border-radius: 0.75rem;
  box-shadow: 0 1px 4px var(--color-shadow);
}

.timeline-header {
  display: flex;
  flex-direction: column;
  gap: 0.125rem;
}

.timeline-title {
  font-size: 1rem;
  font-weight: 600;
  color: var(--color-text);
}

.timeline-subtitle {
  font-size: 0.875rem;
  color: var(--color-text-muted);
  font-weight: 500;
}

.timeline-date {
  font-size: 0.8125rem;
  color: var(--color-text-subtle);
}

.timeline-description {
  font-size: 0.875rem;
  color: var(--color-text-muted);
  line-height: 1.65;
  margin-top: 0.25rem;
}

/* --- Skills --- */
.skills-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
}

.badge {
  display: inline-flex;
  align-items: center;
  padding: 0.3125rem 0.75rem;
  background: var(--color-badge-bg);
  color: var(--color-badge-text);
  border: 1px solid var(--color-badge-border);
  border-radius: 9999px;
  font-size: 0.8125rem;
  font-weight: 500;
  line-height: 1;
  white-space: nowrap;
}

/* --- Projects --- */
.projects-grid {
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
}

.card {
  display: flex;
  flex-direction: column;
  background: var(--color-bg-card);
  border: 1px solid var(--color-border);
  border-radius: 0.75rem;
  overflow: hidden;
  box-shadow: 0 1px 4px var(--color-shadow);
}

.card-image {
  width: 100%;
  height: 11rem;
  object-fit: cover;
}

.card-body {
  padding: 1.25rem;
  display: flex;
  flex-direction: column;
  gap: 0.625rem;
  flex: 1;
}

.card-title {
  font-size: 1rem;
  font-weight: 600;
  color: var(--color-text);
}

.card-description {
  font-size: 0.875rem;
  color: var(--color-text-muted);
  line-height: 1.6;
  flex: 1;
}

.card-footer {
  margin-top: 0.75rem;
}

.btn {
  display: inline-flex;
  align-items: center;
  gap: 0.375rem;
  padding: 0.4375rem 1rem;
  background: var(--color-primary);
  color: #ffffff;
  border-radius: 0.5rem;
  font-size: 0.875rem;
  font-weight: 500;
  text-decoration: none;
  border: none;
  cursor: pointer;
}

.btn:hover {
  background: var(--color-primary-hover);
  color: #ffffff;
  text-decoration: none;
}

.btn:focus-visible {
  outline: 2px solid var(--color-focus);
  outline-offset: 3px;
}

/* --- Achievements --- */
.achievements-list {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.achievement-item {
  padding: 1.25rem;
  background: var(--color-bg-card);
  border: 1px solid var(--color-border);
  border-radius: 0.75rem;
  box-shadow: 0 1px 4px var(--color-shadow);
}

.achievement-title {
  font-size: 1rem;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 0.375rem;
}

.achievement-description {
  font-size: 0.875rem;
  color: var(--color-text-muted);
  line-height: 1.6;
}

/* --- Contact section --- */
.contact-section {
  text-align: center;
}

.contact-intro {
  font-size: 0.9375rem;
  color: var(--color-text-muted);
  line-height: 1.7;
  max-width: 32rem;
  margin: 0 auto 1.5rem;
}

.contact-links {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 0.75rem;
}

.contact-link {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  padding: 0.5rem 1.125rem;
  border: 1px solid var(--color-border);
  border-radius: 0.5rem;
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--color-text);
  background: var(--color-bg-card);
  text-decoration: none;
}

.contact-link:hover {
  border-color: var(--color-primary);
  color: var(--color-primary);
  text-decoration: none;
}

.contact-link:focus-visible {
  outline: 2px solid var(--color-focus);
  outline-offset: 3px;
}

/* --- Footer --- */
footer {
  padding: 2rem 0;
  border-top: 1px solid var(--color-border);
  text-align: center;
}

.footer-text {
  font-size: 0.8125rem;
  color: var(--color-text-subtle);
}

/* --- Responsive: 640px+ --- */
@media (min-width: 640px) {
  .hero .container {
    flex-direction: row;
    text-align: left;
    align-items: center;
    justify-content: space-between;
  }

  .hero-bio {
    margin: 0;
  }

  .avatar {
    width: 8rem;
    height: 8rem;
  }

  .hero-name {
    font-size: 2.75rem;
  }

  .timeline-header {
    flex-direction: row;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
  }

  .timeline-date {
    flex-shrink: 0;
    text-align: right;
  }
}

/* --- Responsive: 768px+ --- */
@media (min-width: 768px) {
  .hero {
    padding: 4rem 0 4.5rem;
  }

  .avatar {
    width: 9.5rem;
    height: 9.5rem;
  }

  .hero-name {
    font-size: 3.25rem;
  }

  main {
    padding: 3rem 0 5rem;
  }

  main .container {
    gap: 3.5rem;
  }

  .card-image {
    height: 13rem;
  }
}

/* --- Reduced motion --- */
@media (prefers-reduced-motion: reduce) {
  html {
    scroll-behavior: auto;
  }

  * {
    transition-duration: 0.01ms !important;
    animation-duration: 0.01ms !important;
  }
}
