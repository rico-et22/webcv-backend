<section id="education" aria-labelledby="education-heading">
  <div class="section-header">
    <span class="section-label">Edukacja</span>
    <h2 class="section-title" id="education-heading">Wykształcenie</h2>
  </div>
  <ol class="timeline" aria-label="Lista wykształcenia">
    {{#each education}}
    <li class="timeline-item">
      <div class="timeline-header">
        <div>
          <h3 class="timeline-title">{{degree}}</h3>
          <p class="timeline-subtitle">{{institution}}</p>
        </div>
        <time class="timeline-date" datetime="{{startDate}}">
          {{formatDate startDate}} — {{formatDate endDate}}
        </time>
      </div>
    </li>
    {{/each}}
  </ol>
</section>
