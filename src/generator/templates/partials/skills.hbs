<section id="skills" aria-labelledby="skills-heading">
  <div class="section-header">
    <span class="section-label">Technologie</span>
    <h2 class="section-title" id="skills-heading">Umiejętności</h2>
  </div>
  <ul class="skills-grid" aria-label="Lista umiejętności">
    {{#each skills}}
    <li><span class="badge">{{this}}</span></li>
    {{/each}}
  </ul>
</section>
