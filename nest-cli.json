{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      { "include": "generator/templates/**/*.hbs", "watchAssets": true },
      { "include": "generator/fonts/*.woff2", "watchAssets": false }
    ]
  }
}
